[gd_scene format=3 uid="uid://bk6r8dyt62v7"]

[ext_resource type="Script" path="res://addons/gd_git_cli/git_diff_view.gd" id="1_diff"]

[node name="GitDiffView" type="VBoxContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_diff")

[node name="Header" type="HBoxContainer" parent="."]
layout_mode = 2

[node name="Title" type="Label" parent="Header"]
layout_mode = 2
size_flags_horizontal = 3
text = "Diff: file.gd"
theme_type_variation = &"HeaderLarge"

[node name="CloseButton" type="Button" parent="Header"]
layout_mode = 2
text = "❌ Fechar Diff"

[node name="ScrollContainer" type="ScrollContainer" parent="."]
layout_mode = 2
size_flags_vertical = 3

[node name="DiffText" type="RichTextLabel" parent="ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_colors/default_color = Color(0.8, 0.8, 0.8, 1)
theme_override_constants/line_separation = 2
bbcode_enabled = true
